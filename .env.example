DATABASE_URL=postgresql://flight_hunter:flight_hunter@localhost:5432/flight_hunter
REDIS_URL=redis://localhost:6379

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Kiwi Tequila API (requires affiliate approval at https://tequila.kiwi.com/)
#KIWI_API_KEY=

# Skyscanner (RapidAPI, paid — https://rapidapi.com/)
#SKYSCANNER_API_KEY=

# Amadeus for Developers (free tier: 2000 req/month — https://developers.amadeus.com/)
# 1. Create account at https://developers.amadeus.com/register
# 2. Create an app in "My Self-Service Apps"
# 3. Copy API Key and API Secret
#AMADEUS_API_KEY=
#AMADEUS_API_SECRET=

# Travelpayouts (free affiliate API — https://www.travelpayouts.com)
# Sign up at https://www.travelpayouts.com and get your token in API settings
#TRAVELPAYOUTS_TOKEN=

# Duffel (sandbox free — https://duffel.com)
# Create account at https://app.duffel.com, enable sandbox, copy API token
#DUFFEL_API_TOKEN=
