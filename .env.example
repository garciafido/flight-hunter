# Flight Hunter dockerized Postgres listens on host port 5433 by default
# (container exposes 5432 internally) so it doesn't clash with a local
# Postgres on 5432. To point at your local Postgres instead, change the
# host/port here and ensure a database/user "flight_hunter" exist.
DATABASE_URL=postgresql://flight_hunter:flight_hunter@localhost:5433/flight_hunter
REDIS_URL=redis://localhost:6379

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

