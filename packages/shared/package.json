{
  "name": "@flight-hunter/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./db": {
      "import": "./dist/db.js",
      "types": "./dist/db.d.ts"
    },
    "./logger": {
      "import": "./dist/utils/logger.js",
      "types": "./dist/utils/logger.d.ts"
    }
  },
  "scripts": {
    "postinstall": "prisma generate || true",
    "build": "prisma generate && tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "seed:current": "tsx scripts/seed-current-search.ts"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.4.0",
    "@vitest/coverage-v8": "^3.0.0",
    "dotenv": "^17.4.1",
    "prisma": "^6.4.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
