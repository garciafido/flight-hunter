generator client {
  provider = "prisma-client"
  output   = "../../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Search {
  id                String    @id @default(uuid()) @db.Uuid
  name              String
  origin            String
  destination       String
  stopover          Json?
  departureFrom     DateTime  @map("departure_from") @db.Date
  departureTo       DateTime  @map("departure_to") @db.Date
  returnMinDays     Int       @map("return_min_days")
  returnMaxDays     Int       @map("return_max_days")
  passengers        Int
  filters           Json
  alertConfig       Json      @map("alert_config")
  proxyRegions      String[]  @map("proxy_regions")
  scanIntervalMin   Int       @map("scan_interval_min")
  active            Boolean   @default(true)
  mode              String    @default("roundtrip")
  legs              Json?
  destinationMode       String   @default("single") @map("destination_mode")
  destinationCandidates Json?    @map("destination_candidates")
  windowMode            Boolean  @default(false) @map("window_mode")
  windowDuration        Int?     @map("window_duration")
  windowFlexibility     Int      @default(0) @map("window_flexibility")
  maxCombos             Int      @default(100) @map("max_combos")
  status            String    @default("active")
  snoozedUntil      DateTime? @map("snoozed_until") @db.Timestamptz
  digestEnabled     Boolean   @default(true) @map("digest_enabled")
  digestFrequency   String    @default("daily") @map("digest_frequency")
  lastDigestSentAt  DateTime? @map("last_digest_sent_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  flightResults   FlightResult[]
  alerts          Alert[]
  priceHistory    PriceHistory[]
  flightCombos    FlightCombo[]
  purchaseRecords PurchaseRecord[]

  @@map("searches")
}

model PurchaseRecord {
  id          String    @id @default(uuid()) @db.Uuid
  searchId    String    @map("search_id") @db.Uuid
  pricePaid   Decimal?  @map("price_paid") @db.Decimal(10, 2)
  currency    String?
  bookingUrl  String?   @map("booking_url")
  travelDate  DateTime? @map("travel_date") @db.Date
  notes       String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  search Search @relation(fields: [searchId], references: [id])

  @@map("purchase_records")
}

model FlightResult {
  id                  String    @id @default(uuid()) @db.Uuid
  searchId            String    @map("search_id") @db.Uuid
  source              String
  outbound            Json
  inbound             Json
  stopoverInfo        Json?     @map("stopover_info")
  pricePerPerson      Decimal   @map("price_per_person") @db.Decimal(10, 2)
  priceTotal          Decimal   @map("price_total") @db.Decimal(10, 2)
  currency            String
  priceOriginal       Decimal   @default(0) @map("price_original") @db.Decimal(10, 2)
  currencyOriginal    String    @default("USD") @map("currency_original")
  priceUsd            Decimal   @default(0) @map("price_usd") @db.Decimal(10, 2)
  exchangeRateAt      DateTime? @map("exchange_rate_at") @db.Timestamptz
  suspicious          Boolean   @default(false)
  suspicionReason     String?   @map("suspicion_reason")
  carryOnIncluded     Boolean   @map("carry_on_included")
  bookingUrl          String    @map("booking_url")
  proxyRegion         String    @map("proxy_region")
  score               Decimal?  @db.Decimal(5, 2)
  scoreBreakdown      Json?     @map("score_breakdown")
  alertLevel          String?   @map("alert_level")
  legIndex            Int       @default(0) @map("leg_index")
  scrapedAt           DateTime  @map("scraped_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz

  search Search  @relation(fields: [searchId], references: [id])
  alerts Alert[]

  @@index([searchId, scrapedAt(sort: Desc)])
  @@index([searchId, pricePerPerson])
  @@index([searchId, legIndex])
  @@map("flight_results")
}

model PriceHistory {
  id          String   @id @default(uuid()) @db.Uuid
  searchId    String   @map("search_id") @db.Uuid
  date        DateTime @db.Date
  minPrice    Decimal  @map("min_price") @db.Decimal(10, 2)
  avgPrice    Decimal  @map("avg_price") @db.Decimal(10, 2)
  maxPrice    Decimal  @map("max_price") @db.Decimal(10, 2)
  bestScore   Decimal  @map("best_score") @db.Decimal(5, 2)
  sampleCount Int      @map("sample_count")

  search Search @relation(fields: [searchId], references: [id])

  @@index([searchId, date])
  @@map("price_history")
}

model Alert {
  id             String    @id @default(uuid()) @db.Uuid
  searchId       String    @map("search_id") @db.Uuid
  flightResultId String    @map("flight_result_id") @db.Uuid
  level          String
  channelsSent   String[]  @map("channels_sent")
  sentAt         DateTime  @map("sent_at") @db.Timestamptz
  feedback       String?
  feedbackAt     DateTime? @map("feedback_at") @db.Timestamptz

  search       Search       @relation(fields: [searchId], references: [id])
  flightResult FlightResult @relation(fields: [flightResultId], references: [id])

  @@index([searchId, sentAt(sort: Desc)])
  @@map("alerts")
}

model FlightCombo {
  id              String   @id @default(uuid()) @db.Uuid
  searchId        String   @map("search_id") @db.Uuid
  flightResultIds String[] @map("flight_result_ids") @db.Uuid
  totalPrice      Decimal  @map("total_price") @db.Decimal(10, 2)
  currency        String
  score           Decimal  @db.Decimal(5, 2)
  scoreBreakdown  Json     @map("score_breakdown")
  alertLevel      String?  @map("alert_level")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  search Search @relation(fields: [searchId], references: [id])

  @@index([searchId, createdAt(sort: Desc)])
  @@map("flight_combos")
}

model Proxy {
  id         String    @id @default(uuid()) @db.Uuid
  label      String
  type       String
  region     String
  host       String
  port       Int
  auth       Json?
  active     Boolean   @default(true)
  lastCheck  DateTime? @map("last_check") @db.Timestamptz
  lastStatus String?   @map("last_status")

  @@map("proxies")
}

model Source {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String    @unique
  enabled             Boolean   @default(true)
  hasApiKey           Boolean   @default(false) @map("has_api_key")
  circuitState        String    @default("closed") @map("circuit_state")
  circuitOpenedAt     DateTime? @map("circuit_opened_at") @db.Timestamptz
  consecutiveFailures Int       @default(0) @map("consecutive_failures")
  lastSuccessAt       DateTime? @map("last_success_at") @db.Timestamptz
  lastFailureAt       DateTime? @map("last_failure_at") @db.Timestamptz
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  metrics SourceMetric[]

  @@map("sources")
}

model SourceMetric {
  id          String   @id @default(uuid()) @db.Uuid
  sourceId    String   @map("source_id") @db.Uuid
  timestamp   DateTime @default(now()) @db.Timestamptz
  success     Boolean
  resultCount Int      @default(0) @map("result_count")
  durationMs  Int      @map("duration_ms")
  errorType   String?  @map("error_type")

  source Source @relation(fields: [sourceId], references: [id])

  @@index([sourceId, timestamp(sort: Desc)])
  @@map("source_metrics")
}

model SystemSettings {
  id                String   @id @default("singleton")
  emailsPaused      Boolean  @default(false) @map("emails_paused")
  webhookUrl        String?  @map("webhook_url")
  webhookEnabled    Boolean  @default(false) @map("webhook_enabled")
  slackWebhookUrl   String?  @map("slack_webhook_url")
  discordWebhookUrl String?  @map("discord_webhook_url")
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@map("system_settings")
}
